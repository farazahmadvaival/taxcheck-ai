# Database Configuration
# Use 'localhost:5433' if running the app locally outside Docker and Postgres inside Docker
# Use 'postgres:5432' if running everything inside Docker Compose
DATABASE_URL=postgresql://tax_ai:tax_ai_password@postgres:5432/tax_ai

# Redis Configuration
# Use 'redis://localhost:6379/0' if running the app locally
# Use 'redis://redis:6379/0' if running everything inside Docker Compose
REDIS_URL=redis://redis:6379/0

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
